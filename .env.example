# Copy this file to .env and fill in the values
# Never commit .env

SPRING_PROFILES_ACTIVE=local

# Database
POSTGRES_DB=afc_local
POSTGRES_USER=afc
POSTGRES_PASSWORD=afc

# Backend (when running outside Docker)
DB_URL=jdbc:postgresql://localhost:5432/afc_local
DB_USERNAME=afc
DB_PASSWORD=afc

# Mobile (passed via --dart-define)
# flutter run --dart-define=FLAVOR=local --dart-define=API_BASE_URL=http://localhost:8080

# ── GitHub Actions Secrets (configure in repo Settings → Secrets) ──────────────
# CI_DB_USERNAME=afc
# CI_DB_PASSWORD=<strong-password>
# STAGING_API_URL=https://api.staging.afc.app
# SONAR_TOKEN=<sonarqube-token>
