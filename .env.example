# Copy this file to .env and fill in the values
# Never commit .env

SPRING_PROFILES_ACTIVE=local

# Database
POSTGRES_DB=afc_local
POSTGRES_USER=afc
POSTGRES_PASSWORD=afc

# Backend local (outside Docker). Railway staging/prod only needs DATABASE_URL + SPRING_PROFILES_ACTIVE.
DB_URL=jdbc:postgresql://localhost:5432/afc_local
DB_USERNAME=afc
DB_PASSWORD=afc

# Mobile (passed via --dart-define)
# flutter run --dart-define=FLAVOR=local --dart-define=API_BASE_URL=http://localhost:8080

# ── GitHub Actions Secrets (configure in repo Settings → Secrets) ──────────────
# CI_DB_USERNAME=afc
# CI_DB_PASSWORD=<strong-password>
#
# Railway
# RAILWAY_TOKEN_STAGING=<railway-project-token-staging>
# RAILWAY_TOKEN_PROD=<railway-project-token-prod>
# STAGING_API_URL=https://<your-service>.up.railway.app
# PROD_API_URL=https://<your-service>.up.railway.app
#
# Android signing
# KEYSTORE_BASE64=<base64-encoded-keystore.jks>   → generate: base64 -i keystore.jks | pbcopy
# KEYSTORE_PASSWORD=<keystore-password>
# KEY_ALIAS=<key-alias>
# KEY_PASSWORD=<key-password>
#
# SonarQube
# SONAR_TOKEN=<sonarqube-token>
